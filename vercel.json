{
    "version": 2,
    "installCommand": "npm install --legacy-peer-deps && (cd Backend && npm install --legacy-peer-deps || true)",
    "buildCommand": "npx parcel build src/index.html",
    "outputDirectory": "dist",
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/server.js" },
        { "src": "/upload/(.*)", "dest": "/api/server.js" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
    "framework": null,
    "buildCommand": "echo 'No build needed'",
    "outputDirectory": ".",
    "installCommand": "npm install --legacy-peer-deps",
    "rewrites": [{
            "source": "/api/(.*)",
            "destination": "/api/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/api/server.js"
        }
    ]
}