{
    "version": 2,
    "installCommand": "npm install --legacy-peer-deps && cd Backend && npm install --legacy-peer-deps",
    "buildCommand": "npx parcel build src/index.html",
    "outputDirectory": "dist",
    "routes": [
        { "src": "/api/(.*)", "dest": "/Backend/server.js" },
        { "src": "/upload/(.*)", "dest": "/Backend/server.js" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}